      "file": "basic_sdxl_scene.json",
      "requires_reference": false,
      "supports_reference": false,
      "required_patch_keys": [
        "checkpoint",
        "prompt",
        "negative_prompt",
        "width",
        "height",
        "seed",
        "steps",
        "cfg",
        "sampler",
        "scheduler",
        "denoise",
        "filename_prefix"
      ],
      "patch": {
        "checkpoint": { "node": "1", "input": "ckpt_name" },
        "prompt": { "node": "2", "input": "text" },
        "negative_prompt": { "node": "3", "input": "text" },
        "width": { "node": "4", "input": "width" },
        "height": { "node": "4", "input": "height" },
        "seed": { "node": "7", "input": "seed" },
        "steps": { "node": "7", "input": "steps" },
