# Keep source files as text with stable line endings.
*.js text eol=lf
*.jsx text eol=lf
*.py text eol=lf
*.json text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.css text eol=lf
*.html text eol=lf
*.bat text eol=crlf

# Treat generated media/binary assets as binary.
*.png binary
*.jpg binary
*.jpeg binary
*.webp binary
*.gif binary
*.mp4 binary
*.mov binary
*.pdf binary
